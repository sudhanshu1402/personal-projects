<?xml version="1.0"?>
<robot name="simple_robot">
  <!--
    Simple 2-Link Robot Arm for Subconscious Robotics Training
    
    Structure:
    - Base (fixed)
    - Link 1: Shoulder joint (revolute, z-axis rotation)
    - Link 2: Elbow joint (revolute, y-axis rotation)
    - End effector
  -->

  <!-- Materials -->
  <material name="gray">
    <color rgba="0.5 0.5 0.5 1"/>
  </material>
  <material name="blue">
    <color rgba="0.2 0.4 0.8 1"/>
  </material>
  <material name="orange">
    <color rgba="0.9 0.5 0.1 1"/>
  </material>

  <!-- Base Link (Fixed) -->
  <link name="base_link">
    <visual>
      <geometry>
        <cylinder radius="0.05" length="0.02"/>
      </geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.05" length="0.02"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <!-- Shoulder Mount -->
  <link name="shoulder_mount">
    <visual>
      <origin xyz="0 0 0.05"/>
      <geometry>
        <cylinder radius="0.03" length="0.1"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.05"/>
      <geometry>
        <cylinder radius="0.03" length="0.1"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.0005" ixy="0" ixz="0" iyy="0.0005" iyz="0" izz="0.0005"/>
    </inertial>
  </link>

  <joint name="base_to_shoulder" type="fixed">
    <parent link="base_link"/>
    <child link="shoulder_mount"/>
    <origin xyz="0 0 0.01"/>
  </joint>

  <!-- Link 1 (Upper Arm) -->
  <link name="upper_arm">
    <visual>
      <origin xyz="0 0 0.15"/>
      <geometry>
        <box size="0.04 0.04 0.3"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.15"/>
      <geometry>
        <box size="0.04 0.04 0.3"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.8"/>
      <origin xyz="0 0 0.15"/>
      <inertia ixx="0.006" ixy="0" ixz="0" iyy="0.006" iyz="0" izz="0.0004"/>
    </inertial>
  </link>

  <!-- Shoulder Joint (Rotation around Z-axis) -->
  <joint name="shoulder_joint" type="revolute">
    <parent link="shoulder_mount"/>
    <child link="upper_arm"/>
    <origin xyz="0 0 0.1"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159" effort="100" velocity="2"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>

  <!-- Link 2 (Forearm) -->
  <link name="forearm">
    <visual>
      <origin xyz="0 0 0.125"/>
      <geometry>
        <box size="0.035 0.035 0.25"/>
      </geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.125"/>
      <geometry>
        <box size="0.035 0.035 0.25"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0 0 0.125"/>
      <inertia ixx="0.003" ixy="0" ixz="0" iyy="0.003" iyz="0" izz="0.0002"/>
    </inertial>
  </link>

  <!-- Elbow Joint (Rotation around Y-axis) -->
  <joint name="elbow_joint" type="revolute">
    <parent link="upper_arm"/>
    <child link="forearm"/>
    <origin xyz="0 0 0.3"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.356" upper="2.356" effort="80" velocity="2.5"/>
    <dynamics damping="0.3" friction="0.1"/>
  </joint>

  <!-- End Effector -->
  <link name="end_effector">
    <visual>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
  </link>

  <joint name="wrist_joint" type="fixed">
    <parent link="forearm"/>
    <child link="end_effector"/>
    <origin xyz="0 0 0.25"/>
  </joint>

</robot>
