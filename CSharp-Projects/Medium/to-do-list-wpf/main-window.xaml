        Title="ToDo List" Height="300" Width="300">
    <StackPanel>
        <TextBox Name="TaskInput" />
        <Button Content="Add Task" Click="AddTask_Click"/>
        <ListBox Name="TasksList" />
    </StackPanel>
</Window>
